@using System.Net.Http.Json
@using System.Security.Claims
@using Microsoft.JSInterop
@implements IDisposable
@inject AudioPlayerService Player
@inject IJSRuntime JS
@inject HttpClient Http
@inject AuthenticationStateProvider AuthProvider

@if (Player.Current != null)
{
    <MudPaper Square="true" Elevation="8"
              Style="position:fixed;bottom:0;left:0;right:0;z-index:1300;border-top:1px solid var(--mud-palette-primary);"
              Class="pa-3 pa-sm-4">

        @* ── Row 1: Track info + close button ── *@
        <div class="d-flex align-center" style="gap:12px;">
            @if (Player.Current.HasCover)
            {
                <MudImage Src="@($"/api/books/{Player.Current.Id}/cover")" Width="52" Height="52"
                          ObjectFit="ObjectFit.Cover" Class="rounded d-sm-none ml-1" Alt="@Player.Current.Title" />
                <MudImage Src="@($"/api/books/{Player.Current.Id}/cover")" Width="64" Height="64"
                          ObjectFit="ObjectFit.Cover" Class="rounded d-none d-sm-flex ml-2" Alt="@Player.Current.Title" />
            }
            else
            {
                <MudAvatar Color="Color.Primary" Size="Size.Small" Class="d-sm-none ml-1">
                    <MudIcon Icon="@Icons.Material.Filled.Headphones" Size="Size.Small" />
                </MudAvatar>
                <MudAvatar Color="Color.Primary" Class="d-none d-sm-flex ml-2">
                    <MudIcon Icon="@Icons.Material.Filled.Headphones" />
                </MudAvatar>
            }
            <div style="min-width:0;flex:1;">
                <MudText Typo="Typo.subtitle2" Style="line-height:1.15" Class="text-truncate">@Player.Current.Title</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary text-truncate">
                    @if (Player.CurrentChapter != null)
                    {
                        <span>@Player.CurrentChapter.Title (@(Player.CurrentChapterIndex + 1)/@Player.Current.Chapters.Count)</span>
                    }
                </MudText>
            </div>
            <MudTooltip Text="Close player">
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="Player.Close"
                               Size="Size.Medium" />
            </MudTooltip>
        </div>

        @* ── Row 2: Audio slider (full width) ── *@
        <div class="mt-3">
            <audio id="globalPlayer"
                   style="width:100%;height:48px;border-radius:8px;filter:saturate(1.2) hue-rotate(-10deg);"
                   controls></audio>
        </div>

        @* ── Row 3: Playback controls ── *@
        <div class="d-flex align-center justify-center mt-2" style="gap:8px;">
            <MudTooltip Text="Previous chapter">
                <MudIconButton Icon="@Icons.Material.Filled.SkipPrevious"
                               Disabled="!Player.HasPrevious" OnClick="Previous"
                               Color="Color.Primary" Size="Size.Large" />
            </MudTooltip>

            <MudTooltip Text="Next chapter">
                <MudIconButton Icon="@Icons.Material.Filled.SkipNext"
                               Disabled="!Player.HasNext" OnClick="Next"
                               Color="Color.Primary" Size="Size.Large" />
            </MudTooltip>

            <MudMenu Icon="@Icons.Material.Filled.Bedtime" Color="Color.Default" Size="Size.Medium" Dense="true"
                     Label="Sleep timer" AriaLabel="Sleep timer">
                <MudMenuItem OnClick="() => SetSleepTimerAsync(15)">15m</MudMenuItem>
                <MudMenuItem OnClick="() => SetSleepTimerAsync(30)">30m</MudMenuItem>
                <MudMenuItem OnClick="() => SetSleepTimerAsync(45)">45m</MudMenuItem>
                <MudMenuItem OnClick="() => SetSleepTimerAsync(60)">60m</MudMenuItem>
                <MudDivider />
                <MudMenuItem Disabled="!SleepTimerIsSet" OnClick="UnsetSleepTimer">Unset</MudMenuItem>
            </MudMenu>

            @if (SleepTimerIsSet)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                         Color="Color.Info" Icon="@Icons.Material.Filled.Timer">
                    @SleepTimerStatus
                </MudChip>
            }
        </div>
    </MudPaper>
}

@code {
    int? _loadedChapterId;
    DotNetObjectReference<GlobalAudioPlayer>? _selfRef;
    CancellationTokenSource? _sleepTimerCts;
    DateTimeOffset? _sleepTimerEndsAt;

    string Src => Player.CurrentChapter == null ? string.Empty : $"/api/chapters/{Player.CurrentChapter.Id}/audio";
    bool SleepTimerIsSet => _sleepTimerEndsAt != null;
    string SleepTimerStatus => _sleepTimerEndsAt == null
        ? string.Empty
        : FormatSleepTimerStatus(_sleepTimerEndsAt.Value - DateTimeOffset.UtcNow);

    protected override void OnInitialized()
    {
        Player.Changed += OnChanged;
        Player.Closed += OnClosed;
    }

    void OnChanged() => InvokeAsync(StateHasChanged);

    async void OnClosed()
    {
        CancelSleepTimer();
        await JS.InvokeVoidAsync("disposeAudioPlayer");
        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initAudioPlayer", _selfRef);
        }

        if (Player.CurrentChapter == null)
        {
            _loadedChapterId = null;
            return;
        }

        if (Player.CurrentChapter.Id != _loadedChapterId)
        {
            _loadedChapterId = Player.CurrentChapter.Id;
            var seek = Player.ConsumePendingSeek();
            await JS.InvokeVoidAsync("loadPlaySeek", "globalPlayer", Src, seek);
            await JS.InvokeVoidAsync("updateMediaSession",
                Player.Current?.Title ?? "",
                Player.CurrentChapter.Title,
                Player.Current?.Title ?? "");
        }
    }

    // Called from JS media session handlers
    [JSInvokable]
    public async Task MediaNext()
    {
        await SaveProgressAsync();
        Player.Next();
    }

    [JSInvokable]
    public async Task MediaPrevious()
    {
        await SaveProgressAsync();
        Player.Previous();
    }

    // Called from JS audio element event handlers
    [JSInvokable]
    public async Task OnJsPause() => await SaveProgressAsync();

    [JSInvokable]
    public async Task OnJsEnded()
    {
        await SaveProgressAsync();
        Player.Next();
    }

    [JSInvokable]
    public async Task OnJsTimeUpdate() => await SaveProgressAsync();

    async Task Next()
    {
        await SaveProgressAsync();
        Player.Next();
    }

    async Task Previous()
    {
        await SaveProgressAsync();
        Player.Previous();
    }

    Task SetSleepTimerAsync(int minutes)
    {
        CancelSleepTimer();

        _sleepTimerEndsAt = DateTimeOffset.UtcNow.AddMinutes(minutes);
        _sleepTimerCts = new CancellationTokenSource();
        _ = RunSleepTimerAsync(_sleepTimerCts.Token);

        StateHasChanged();
        return Task.CompletedTask;
    }

    void UnsetSleepTimer()
    {
        CancelSleepTimer();
        StateHasChanged();
    }

    async Task RunSleepTimerAsync(CancellationToken cancellationToken)
    {
        if (_sleepTimerEndsAt == null) return;

        try
        {
            while (_sleepTimerEndsAt != null)
            {
                var remaining = _sleepTimerEndsAt.Value - DateTimeOffset.UtcNow;
                if (remaining <= TimeSpan.Zero) break;

                await InvokeAsync(StateHasChanged);
                var nextTick = remaining > TimeSpan.FromSeconds(1)
                    ? TimeSpan.FromSeconds(1)
                    : remaining;
                await Task.Delay(nextTick, cancellationToken);
            }

            await JS.InvokeVoidAsync("pauseAudio", "globalPlayer");
            await SaveProgressAsync();
            CancelSleepTimer();
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException)
        {
            // Timer was unset or replaced.
        }
    }

    void CancelSleepTimer()
    {
        _sleepTimerCts?.Cancel();
        _sleepTimerCts?.Dispose();
        _sleepTimerCts = null;
        _sleepTimerEndsAt = null;
    }

    static string FormatSleepTimerStatus(TimeSpan remaining)
    {
        if (remaining < TimeSpan.Zero) remaining = TimeSpan.Zero;

        var totalSeconds = (int)Math.Ceiling(remaining.TotalSeconds);
        var minutes = totalSeconds / 60;
        var seconds = totalSeconds % 60;
        return $"Sleep in {minutes:D2}:{seconds:D2}";
    }

    async Task SaveProgressAsync()
    {
        if (Player.CurrentChapter == null || Player.Current == null) return;

        var userId = await UserIdAsync();
        if (userId <= 0) return;

        var current = await JS.InvokeAsync<double>("getCurrentTime", "globalPlayer");

        await Http.PostAsJsonAsync($"/api/users/{userId}/progress",
            new { BookId = Player.Current.Id, ChapterId = Player.CurrentChapter.Id, PositionSec = (int)current });
    }

    async Task<int> UserIdAsync()
    {
        var user = (await AuthProvider.GetAuthenticationStateAsync()).User;
        return int.TryParse(user.FindFirstValue(ClaimTypes.NameIdentifier), out var id) ? id : 0;
    }

    public void Dispose()
    {
        CancelSleepTimer();
        Player.Changed -= OnChanged;
        Player.Closed -= OnClosed;
        _selfRef?.Dispose();
    }
}
