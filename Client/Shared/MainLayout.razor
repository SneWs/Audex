@inherits LayoutComponentBase
@using System.Net.Http.Json
@using Grenis.AudioBooks.Core
@using Blazored.LocalStorage
@using Microsoft.JSInterop
@inject TokenAuthenticationStateProvider AuthProvider
@inject HttpClient Http
@inject ILocalStorageService LocalStorage
@inject IJSRuntime JS
@inject NavigationManager Nav

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudIcon Icon="@Icons.Material.Filled.Headphones" Class="ml-2" />
        <MudText Typo="Typo.h6" Class="ml-2">Audex</MudText>
        <MudSpacer />
        <MudTooltip Text="Toggle light/dark mode">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit" OnClick="ToggleThemeAsync" />
        </MudTooltip>
        <AuthorizeView>
            <Authorized>
                <MudTooltip Text="Account">
                    <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" Href="/account" />
                </MudTooltip>
                <MudButton StartIcon="@Icons.Material.Filled.Logout" Color="Color.Inherit" OnClick="LogoutAsync">Logout</MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton StartIcon="@Icons.Material.Filled.Login" Color="Color.Inherit" Href="/login">Login</MudButton>
                <MudButton StartIcon="@Icons.Material.Filled.PersonAdd" Color="Color.Inherit" Href="/register">Register</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Menu</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <AuthorizeView>
                <Authorized>
                    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.LibraryBooks">My Library</MudNavLink>
                    <MudNavLink Href="/recents" Icon="@Icons.Material.Filled.NewReleases">Recents</MudNavLink>
                    <MudNavLink Href="/continue" Icon="@Icons.Material.Filled.PlayCircleOutline">Continue Listening</MudNavLink>
                    <MudNavLink Href="/favorites" Icon="@Icons.Material.Filled.Favorite">Favorites</MudNavLink>
                    <MudNavLink Href="/search" Icon="@Icons.Material.Filled.Search">Search</MudNavLink>
                    <MudDivider Class="my-2" />
                    <MudNavLink Href="/account" Icon="@Icons.Material.Filled.AccountCircle">Account</MudNavLink>
                </Authorized>
                <NotAuthorized>
                    <MudNavLink Href="/login" Icon="@Icons.Material.Filled.Login">Login</MudNavLink>
                    <MudNavLink Href="/register" Icon="@Icons.Material.Filled.PersonAdd">Register</MudNavLink>
                </NotAuthorized>
            </AuthorizeView>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-6" Style="padding-bottom:260px;">
            @Body
        </MudContainer>
    </MudMainContent>

    <GlobalAudioPlayer />
</MudLayout>

@code {
    bool _drawerOpen = true;
    bool _isDarkMode;

    readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#7c4dff",
            Secondary = "#9c27b0",
            AppbarBackground = "#7c4dff",
            AppbarText = "#ffffff",
            Background = "#f8f5ff",
            Surface = "#ffffff",
            DrawerBackground = "#f0eaff",
            DrawerText = "#2b2b2b",
            TextPrimary = "#2b2b2b",
            TextSecondary = "#5f5f7a"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#7c4dff",
            Secondary = "#c77dff",
            AppbarBackground = "#1a1832",
            AppbarText = "#fffffe",
            Background = "#0f0e17",
            Surface = "#1a1832",
            DrawerBackground = "#1a1832",
            DrawerText = "#e0dcf7",
            TextPrimary = "#fffffe",
            TextSecondary = "#a89fcc"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["Roboto", "Helvetica", "Arial", "sans-serif"]
            }
        }
    };

    protected override void OnInitialized()
    {
        AuthProvider.AuthenticationStateChanged += HandleAuthenticationStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDarkMode = await JS.InvokeAsync<bool>("getStoredDarkMode");
            StateHasChanged();
            await LoadThemePreferenceAsync();
        }
    }

    async void HandleAuthenticationStateChanged(Task<AuthenticationState> authTask)
    {
        var authState = await authTask;
        if (authState.User.Identity?.IsAuthenticated == true)
            await LoadThemePreferenceAsync();

        await InvokeAsync(StateHasChanged);
    }

    void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    async Task ToggleThemeAsync()
    {
        _isDarkMode = !_isDarkMode;
        await LocalStorage.SetItemAsync("darkMode", _isDarkMode);
        StateHasChanged();

        try
        {
            var res = await Http.PutAsJsonAsync("/api/account/preferences/theme", new ThemePreferenceRequest
            {
                IsDarkMode = _isDarkMode
            });
            if (!res.IsSuccessStatusCode)
                await RestoreServerPreferenceAsync();
        }
        catch
        {
            await RestoreServerPreferenceAsync();
        }
    }

    async Task LoadThemePreferenceAsync()
    {
        try
        {
            var account = await Http.GetFromJsonAsync<AccountDto>("/api/account");
            if (account is not null)
            {
                _isDarkMode = account.PrefersDarkMode;
                await LocalStorage.SetItemAsync("darkMode", _isDarkMode);
                StateHasChanged();
            }
        }
        catch
        {
            // Anonymous users or network failures keep the cached/default theme.
        }
    }

    async Task RestoreServerPreferenceAsync()
    {
        try
        {
            await LoadThemePreferenceAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Ignore secondary failures when attempting to restore server state.
        }
    }

    async Task LogoutAsync()
    {
        await AuthProvider.MarkUserAsLoggedOut();
        Nav.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthProvider.AuthenticationStateChanged -= HandleAuthenticationStateChanged;
    }
}
